# Recon Tool Configuration
# Copy this file to .env and fill in your API keys

# NVD/NIST API Key (optional, increases rate limit)
NVD_API_KEY=

# Shodan API Key
SHODAN_API_KEY=

# GitHub Personal Access Token (for Advisory API)
GITHUB_TOKEN=

# SecurityTrails API Key
SECURITYTRAILS_API_KEY=

# VirusTotal API Key
VIRUSTOTAL_API_KEY=

# HackerOne API (for submission)
HACKERONE_API_IDENTIFIER=
HACKERONE_API_TOKEN=

# Proxy Configuration
PROXY_URL=
PROXY_LIST_FILE=

# Server Configuration
API_PORT=3000
API_HOST=127.0.0.1

# Database (optional - defaults to file-based storage)
MONGODB_URI=
REDIS_URL=

# Notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Rate Limiting
MAX_REQUESTS_PER_SECOND=10
MAX_CONCURRENT_SCANS=5

# ═══════════════════════════════════════════════════
# AI-ASSISTED SCANNING
# ═══════════════════════════════════════════════════
# Provider: deepseek, openai, claude, groq, gemini
AI_PROVIDER=deepseek
AI_API_KEY=
AI_MODEL=deepseek-chat
# Alternative models:
#   deepseek: deepseek-chat, deepseek-reasoner
#   openai: gpt-4o, gpt-4o-mini, gpt-4-turbo
#   claude: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
#   groq: llama-3.1-70b-versatile, mixtral-8x7b-32768
#   gemini: gemini-1.5-pro, gemini-1.5-flash

# Dashboard
DASHBOARD_PORT=4500
DASHBOARD_HOST=0.0.0.0
